# Copy to web/.env and fill from the CDK stack Outputs after deploy.
# All client-safe (Cognito IDs and AppSync URL are public by design).
VITE_GRAPHQL_URL=
VITE_GRAPHQL_API_KEY=
VITE_AWS_REGION=us-east-1
VITE_USER_POOL_ID=
VITE_USER_POOL_CLIENT_ID=
VITE_UPLOAD_BUCKET=
VITE_VAPID_PUBLIC=BEfF6WvZnbcUDuYvw2WMnra7k-FXycjg-6y10eCkNSJ9ozwdTvfnshHOwzv5cTCDTnzW8uh_WKIKcLde_DAwn74
# Cognito Hosted-UI domain (enables Google/Apple sign-in). Set after the social
# login deploy: <cognitoDomainPrefix>.auth.<region>.amazoncognito.com
VITE_COGNITO_DOMAIN=
# Which federated providers are live (comma-separated): "Google", "Apple", or both.
VITE_OAUTH_PROVIDERS=
